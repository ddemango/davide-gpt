# ==============================================
# DavideGPT.ai — Environment Variables
# ==============================================

# Analytics — Replace with your real tracking ID
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Email / CRM integrations
# Uncomment and fill in as needed:

# ConvertKit / Newsletter
# CONVERTKIT_API_KEY=your_key_here
# CONVERTKIT_FORM_ID=your_form_id_here

# HubSpot
# HUBSPOT_ACCESS_TOKEN=your_token_here
# HUBSPOT_PORTAL_ID=your_portal_id

# GoHighLevel
# GHL_API_KEY=your_key_here
# GHL_LOCATION_ID=your_location_id

# Zapier Webhook (contact form)
# ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/yyyyyy/

# Make.com (formerly Integromat)
# MAKE_WEBHOOK_URL=https://hook.eu1.make.com/xxxxx

# Airtable
# AIRTABLE_API_KEY=your_key_here
# AIRTABLE_BASE_ID=your_base_id
# AIRTABLE_TABLE_NAME=Leads

# Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Cal.com or Calendly embed
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/davidegpt/30min

# Site URL (used for OG tags and sitemaps)
NEXT_PUBLIC_SITE_URL=https://davidegpt.ai
